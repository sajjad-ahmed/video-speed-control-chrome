{
  "manifest_version": 3,
  "name": "Video Speed Controller Pro",
  "version": "0.1.0",
  "author": "Sajjad Ahmed Niloy",
  "description": "Control video playback speed (0.25x–4.00x) globally or site specific. Instant updates, no refresh needed.",
  "homepage_url": "https://sajjadahmed.com",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Video Speed Controller Pro"
  },
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "webNavigation"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
